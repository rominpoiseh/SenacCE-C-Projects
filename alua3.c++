#include <iostream>
int main(){
    int a = 7;
    int b = 5;
    int soma = a + b;
    std::cout<< "Soma de " << a << " + " << b << " = " << soma << "\n"; 
    return 0;
} // O operador << insere os dados sequencialmente no fluxo de saída.
//Operador de inserção << envia os dados para o console
//\n por encerrar a linha e iniciar uma nova o programa entende que deve "rodar" o comando e exibir a informação no console.